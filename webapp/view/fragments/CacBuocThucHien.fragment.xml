<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.ui.layout.form"
>
    <VBox width="100%">
        <Toolbar>
            <Title text="{i18n>danhSachBuoc}" />

            <ToolbarSpacer />


            <Button
                text="Add"
                icon="sap-icon://add"
                type="Emphasized"
                press="openCreateStepDialog"
            />
            <Button
                text="Edit"
                icon="sap-icon://edit"
                type="Emphasized"
                press="onEditStepDialog"
                enabled="{= ${stepTableModel>/selectedIndices}.length === 1}"
            />
            <Button
                text="{i18n>xoaBuoc}"
                icon="sap-icon://delete"
                type="Negative"
                press="onDeleteStep"
                enabled="{= ${stepTableModel>/selectedIndices}.length === 1}"
            />
        </Toolbar>

        <t:Table
            id="tableSteps"
            rows="{project>/StepList}"
            selectionMode="Single"
            selectionBehavior="Row"
            rowSelectionChange="onRowSelectionChange"
        >
            <t:columns>
                <t:Column>
                    <Label text="{i18n>StepId}" />
                    <t:template>
                        <Text text="{project>StepId}" />
                    </t:template>
                </t:Column>

                <t:Column>
                    <Label text="{i18n>tenBuoc}" />
                    <t:template>
                        <Link
                            text="{path: 'project>StepId', formatter: '.formatStepName'}"
                            press="onPressStep"
                        />
                    </t:template>
                </t:Column>

                <t:Column>
                    <Label text="{i18n>trangThai}" />
                    <t:template>
                        <ObjectStatus
                            text="{path: 'project>Status', formatter: '.formatStepStatusText'}"
                            inverted="true"
                            state="{path: 'project>Status', formatter: '.formatStepStatusState'}"
                        />
                    </t:template>
                </t:Column>

                <t:Column>
                    <Label text="{i18n>ngayBatDau}" />
                    <t:template>
                        <Text text="{project>PlanStart}" />
                    </t:template>
                </t:Column>

                <t:Column>
                    <Label text="Deadline" />
                    <t:template>
                        <Text text="{project>Deadline}" />
                    </t:template>
                </t:Column>
                <t:Column>
                    <Label text="Pic1" />
                    <t:template>
                        <Text text="{project>Pic1}" />
                    </t:template>
                </t:Column>
                <t:Column>
                    <Label text="Pic2" />
                    <t:template>
                        <Text text="{project>Pic2}" />
                    </t:template>
                </t:Column>
                <t:Column>
                    <Label text="Pic3" />
                    <t:template>
                        <Text text="{project>Pic3}" />
                    </t:template>
                </t:Column>
            </t:columns>
        </t:Table>
    </VBox>
</core:FragmentDefinition>
