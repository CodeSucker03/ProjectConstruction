<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.m.upload"
>
    <Panel>
        <VBox>
            <Title text="To trinh" />
            <VBox>
                <u:UploadSet
                    id="UploadSetProj"
                    mode="None"
                    items="{ProjectDocumentInit>/DocumentList}"
                    beforeItemRemoved="onBeforeItemRemoved"
                    beforeItemAdded="onBeforeItemAdded"
                    afterItemAdded="onAfterItemAdded"
                    uploadEnabled="true"
                >
                    <u:items>
                        <u:UploadSetItem
                            url="{ProjectDocumentInit>Url}"
                            fileName="{ProjectDocumentInit>FileName}"
                            mediaType="{ProjectDocumentInit>Mimetype}"
                            openPressed="onOpenPressed"
                            visibleEdit="false"
                        >
                            <u:attributes>
                                <ObjectAttribute
                                    title="Người tạo"
                                    text="{ProjectDocumentInit>CreateBy}"
                                    active="false"
                                />
                                <ObjectAttribute
                                    title="Ngày tạo"
                                    text="{ProjectDocumentInit>CreateDate} {ProjectDocumentInit>CreateTime}"
                                    active="false"
                                />
                            </u:attributes>
                        </u:UploadSetItem>
                    </u:items>
                </u:UploadSet>
            </VBox>
        </VBox>
    </Panel>
</core:FragmentDefinition>
