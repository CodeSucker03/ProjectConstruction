<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.m.upload"
>
    <Panel>
        <VBox>
            <Title text="To trinh" />
            <VBox>
                <u:UploadSet
                    id="UploadSetA"
                    mode="None"
                    items="{ProjectDocument>/DAUBAI_LIST}"
                    beforeItemRemoved="onBeforeItemRemoved"
                    beforeItemAdded="onBeforeItemAdded"
                    uploadEnabled="true"
                    uploadButtonInvisible="{path:'trangThaiPheDuyet>/levels/0/Action'}"
                >
                    <u:items>
                        <u:UploadSetItem
                            url="{ProjectDocument>Url}"
                            fileName="{ProjectDocument>FileName}"
                            mediaType="{ProjectDocument>Mimetype}"
                            openPressed="onOpenPressed"
                            visibleEdit="false"
                            visibleRemove="{trangThaiPheDuyet>/levels/0/Action}"
                        >
                            <u:attributes>
                                <ObjectAttribute
                                    title="Người tạo"
                                    text="{ProjectDocument>CreateBy}"
                                    active="false"
                                />
                                <ObjectAttribute
                                    title="Ngày tạo"
                                    text="{ProjectDocument>CreateDate} {ProjectDocument>CreateTime}"
                                    active="false"
                                />
                            </u:attributes>
                        </u:UploadSetItem>
                    </u:items>
                </u:UploadSet>
            </VBox>
        </VBox>
    </Panel>
</core:FragmentDefinition>
