<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.m.upload"
    xmlns:customData="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
>
    <Panel>
        <VBox>
            <Title text="To trinh" />
            <VBox>
                <u:UploadSet
                    id="UploadSetProj"
                    mode="None"
                    beforeItemAdded="onBeforeItemAdded"
                    items="{PrjDocumentInit>/DocumentList}"
                    uploadEnabled="true"
                    beforeItemRemoved="onItemDeleteFileZ9"
                    
                >
                    <u:items>
                        <u:UploadSetItem
                            fileName="{PrjDocumentInit>Filename}"
                            mediaType="{PrjDocumentInit>MimeType}"
                            removePressed="onItemDeleteFileZ9"
                            customData:FileId="{PrjDocumentInit>FileId}"
                            openPressed="onOpenPressed"
                            visibleEdit="false"
                            url="{PrjDocumentInit>Url}"
                    
                        >
                            <u:attributes>
                                <ObjectAttribute
                                    title="Người tạo"
                                    text="{PrjDocumentInit>CreateBy}"
                                    active="false"
                                />
                                <ObjectAttribute
                                    title="Ngày tạo"
                                    text="{PrjDocumentInit>CreateDate} {PrjDocumentInit>CreateTime}"
                                    active="false"
                                />
                            </u:attributes>
                        </u:UploadSetItem>
                    </u:items>
                </u:UploadSet>
            </VBox>
        </VBox>
    </Panel>
</core:FragmentDefinition>
