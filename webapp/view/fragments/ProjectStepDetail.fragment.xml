<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:u="sap.m.upload"
>
    <Dialog
        id="stepDialog"
        title="{projectStepDetail>StepName}"
        contentWidth="900px"
        contentHeight="650px"
        draggable="true"
        resizable="true"
        binding="{projectStepDetail>/}"
    >
        <content>
            <VBox class="sapUiMediumMargin">
                <MessageStrip
                    text="{path: 'projectStepDetail>StartStatus', formatter: '.formatStepStartStatusText'}"
                    type="{path: 'projectStepDetail>StartStatus', formatter: '.formatStepStartStatusState'}"
                    showIcon="true"
                    class="sapUiMediumMarginBottom"
                />

                <IconTabBar>
                    <items>
                        <IconTabFilter
                            text="Thông tin"
                            icon="sap-icon://detail-view"
                        >
                            <f:SimpleForm
                                editable="true"
                                layout="ResponsiveGridLayout"
                            >
                                <f:content>
                                    <Label text="Tên bước" />
                                    <Select
                                        id="selStep"
                                        selectedKey="{projectStepDetail>StepId}"
                                        items="{stepPool>/availableSteps}"
                                        change=".onStepSelected"
                                        width="250px"
                                    >
                                        <core:Item
                                            key="{stepPool>StepId}"
                                            text="{stepPool>StepName}"
                                        />
                                    </Select>

                                    <Label text="Trạng thái" />
                                    <Select
                                        selectedKey="{projectStepDetail>Status}"
                                    >
                                        <core:Item
                                            key="0"
                                            text="Chưa triển khai"
                                        />
                                        <core:Item
                                            key="1"
                                            text="Đang triển khai"
                                        />
                                        <core:Item
                                            key="2"
                                            text="Hoàn thành"
                                        />
                                    </Select>

                                    <Label text="Ngày bắt đầu" />
                                    <DatePicker
                                        value="{projectStepDetail>PlanStart}"
                                        valueFormat="yyyy-MM-dd"
                                        displayFormat="dd/MM/yyyy"
                                    />

                                    <Label text="Deadline" />
                                    <DatePicker
                                        valueFormat="yyyy-MM-dd"
                                        displayFormat="dd/MM/yyyy"
                                        value="{projectStepDetail>Deadline}"
                                    />
                                </f:content>
                            </f:SimpleForm>
                        </IconTabFilter>

                        <IconTabFilter
                            text="Trao đổi"
                            icon="sap-icon://discussion"
                        >
                            <VBox>
                                <FeedInput
                                    post=".onPost"
    
                                    class="sapUiSmallMarginTopBottom"
                                />
                                <List
                                    showSeparators="Inner"
                                    items="{projectStepDetail>/comments}"
                                >
                                    <FeedListItem
                                        sender="{projectStepDetail>Author}"
                                        timestamp="{projectStepDetail>Date}"
                                        text="{projectStepDetail>Text}"
                                        convertLinksToAnchorTags="All"
                                    />
                                </List>
                            </VBox>
                        </IconTabFilter>

                        <IconTabFilter
                            text="Tài liệu"
                            icon="sap-icon://attachment"
                        >
                            <VBox>
                                <u:UploadSet
                                    id="UploadSetStepA"
                                    mode="None"
                                    items="{projectStepDetail>/stepDocuments}"
                                    beforeItemRemoved="onBeforeItemRemoved"
                                    beforeItemAdded="onBeforeItemAdded"
                                    uploadEnabled="true"
                                >
                                    <u:items>
                                        <u:UploadSetItem
                                            url="{projectStepDetail>Url}"
                                            fileName="{projectStepDetail>FileName}"
                                            mediaType="{projectStepDetail>Mimetype}"
                                            openPressed="onOpenPressed"
                                            visibleEdit="false"
                                        >
                                            <u:attributes>
                                                <ObjectAttribute
                                                    title="Người tạo"
                                                    text="{projectStepDetail>CreateBy}"
                                                    active="false"
                                                />
                                                <ObjectAttribute
                                                    title="Ngày tạo"
                                                    text="{projectStepDetail>CreateDate} {projectStepDetail>CreateTime}"
                                                    active="false"
                                                />
                                            </u:attributes>
                                        </u:UploadSetItem>
                                    </u:items>
                                </u:UploadSet>
                            </VBox>

                            <!-- uploadset -->
                        </IconTabFilter>
                    </items>
                </IconTabBar>
            </VBox>
        </content>

        <beginButton>
            <Button
                text="Lưu"
                type="Emphasized"
                press=".onSaveStep"
            />
        </beginButton>

        <endButton>
            <Button
                text="Đóng"
                press=".onCloseStepDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
