<mvc:View
    controllerName="sphinx.project.controller.Project"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:uxap="sap.uxap"
    xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    height="100%"
>
    <uxap:ObjectPageLayout
        id="objectPageLayout"
        showFooter="true"
    >
        <uxap:headerTitle>
            <uxap:ObjectPageHeader
                objectTitle="{parts:[{path:'ProjectStageModel>/isCreateStage'}, {path:'projectInitForm>/BranchName'}], formatter:'.formatHeaderTitle'}"
                objectSubtitle="{parts:[{path:'ProjectStageModel>/isCreateStage'}, {path:'projectInitForm>/BookId'}], formatter:'.formatHeaderSubtitle'}"
                objectImageShape="Circle"
                isObjectTitleAlwaysVisible="true"
                isObjectSubtitleAlwaysVisible="true"
                showPlaceholder="true"
            />
        </uxap:headerTitle>

        <uxap:headerContent>
            <ObjectStatus
                id="status"
                visible="{= !${ProjectStageModel>/isCreateStage}}"
                text="{parts:[{path:'projectInitForm>Status'}], formatter:'.getStatusText'}"
                state="{parts:['projectInitForm>Status'], formatter:'.getState'}"
                inverted="true"
                class="sapUISmallMarginBottom"
            />
        </uxap:headerContent>

        <uxap:sections>
            <uxap:ObjectPageSection
                visible="{= ${ProjectStageModel>/Step} === 0 }"
                title="Công cụ hỗ trợ nhập liệu nhanh"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <Panel
                                headerText="Công cụ hỗ trợ nhập liệu nhanh"
                                class="sapUiSmallMargin"
                            >
                                <HBox
                                    wrap="Wrap"
                                    alignItems="Center"
                                >
                                    <VBox class="sapUiMediumMarginEnd">
                                        <Label
                                            text="Tải lên văn bản (Scan, Ảnh,...) để OCR tự động điền:"
                                        />
                                        <u:FileUploader
                                            id="ocrUploader"
                                            name="ocrFile"
                                            change="UploadScanFile"
                                            placeholder="Chọn file ảnh/scan..."
                                            buttonText="Tải lên &amp; OCR"
                                        />
                                    </VBox>
                                </HBox>
                            </Panel>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection title="Thông tin dự án">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <core:Fragment
                                fragmentName="sphinx.project.view.fragments.ProjectForm"
                                type="XML"
                            />
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection title="Tờ trình chủ trương ">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <core:Fragment
                                fragmentName="sphinx.project.view.fragments.UploadDocument"
                                type="XML"
                            />
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                id="Assignment"
                title="Cán bộ phân công"
              visible="{= ${ProjectStageModel>/Step} >= 2 &amp;&amp; ${ProjectStageModel>/Step} !== 5 }"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection
                        id="subSecPhanCong"
                        class="sapUiSmallMarginTop"
                    >
                        <uxap:blocks>
                            <core:Fragment
                                fragmentName="sphinx.project.view.fragments.PhanCongCanBo"
                                type="XML"
                            />
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                title="Thông tin Nhà thầu thực hiện"
                visible="{= ${ProjectStageModel>/Step} >= 5 }"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <core:Fragment
                                fragmentName="sphinx.project.view.fragments.ContractorList"
                                type="XML"
                            />
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                title="Lịch sử phê duyệt"
                visible="{= ${ProjectStageModel>/Step} >= 2 }"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <core:Fragment
                                fragmentName="sphinx.project.view.fragments.ApprovalHistory"
                                type="XML"
                            />
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                title="Các bước thực hiện"
                visible="{= !${ProjectStageModel>/isCreateStage}}"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <core:Fragment
                                fragmentName="sphinx.project.view.fragments.CacBuocThucHien"
                                type="XML"
                            />
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>

        <uxap:footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    type="Accept"
                    text="Gửi dự án"
                    icon="sap-icon://accept"
                    visible="{= ${ProjectStageModel>/isCreateStage}}"
                    enabled="{= ${ProjectStageModel>/Step} === 0 }"
                    press="onSubmitProject"
                />

                <Button
                    type="Accept"
                    text="Hoàn thiện phân quyền"
                    icon="sap-icon://accept"
                    visible="{= ${ProjectStageModel>/isRoleAssignStage}}"
                    enabled="{= ${ProjectStageModel>/Step} === 2 
                    || ${ProjectStageModel>/Step} === 3 
                    || ${ProjectStageModel>/Step} === 4}"
                    press="onActionAssignSubmit"
                />
                <Button
                    type="Accept"
                    text="Hoàn thiện nhà thầu"
                    icon="sap-icon://accept"
                    visible="{= ${ProjectStageModel>/isContractorStage}}"
                    enabled="{= ${ProjectStageModel>/Step} === 5 }"
                    press="onActionSendContractor"
                />
                <Button
                    type="Accept"
                    text="Phê duyệt dự án"
                    icon="sap-icon://accept"
                    app:buttonData="Y"
                    visible="{= ${ProjectStageModel>/isApproveStage}}"
                    enabled="{= ${ProjectStageModel>/Step} === 6 
                    || ${ProjectStageModel>/Step} === 7 
                    || ${ProjectStageModel>/Step} === 1 }"
                    press="onPressApprovalStage"
                />
                <Button
                    type="Reject"
                    text="Từ chối dự án"
                    app:buttonData="N"
                    icon="sap-icon://decline"
                    visible="{= ${ProjectStageModel>/isApproveStage} }"
                    enabled="{= ${ProjectStageModel>/Step} === 6 
                    || ${ProjectStageModel>/Step} === 7 
                    || ${ProjectStageModel>/Step} === 1 }"
                    press="onPressApprovalStage"
                />
                <Button
                    type="Attention"
                    text="Yêu cầu sửa dự án"
                    app:buttonData="B"
                    icon="sap-icon://edit"
                    visible="{= ${ProjectStageModel>/isApproveStage} }"
                    enabled="{= ${ProjectStageModel>/Step} === 6 
                    || ${ProjectStageModel>/Step} === 7 
                    || ${ProjectStageModel>/Step} === 1}"
                    press="onPressApprovalStage"
                />
            </OverflowToolbar>
        </uxap:footer>
    </uxap:ObjectPageLayout>
</mvc:View>
